# Core infra (required — config/env.ts crashes at boot if a required var is missing)
NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://kss:kss@localhost:5432/kss
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=dev-access-secret-change-me-32bytes-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32bytes-min
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# External services (required only in the phases that use them — optional in dev)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
ANTHROPIC_API_KEY=
SARVAM_API_KEY=
GOOGLE_STT_API_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
EXPO_ACCESS_TOKEN=
SENTRY_DSN=
