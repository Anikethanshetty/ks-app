// Krishnappa Shetty and Son's — database schema.
// Mirrors docs/05-backend-schema-document.md §2–4 exactly (SQL is the source of truth).
//
// Things Prisma cannot express live in a raw SQL migration (see §9 of the doc):
//   - partial / filtered indexes (one_default_address, one_active_assignment,
//     one_default_variant, and every `... WHERE ...` index)
//   - CHECK constraints (pincode regex, stock >= 0, id = 1, language IN (...), ...)
//   - sequences (order_number_seq, invoice_number_seq)
//   - the v_voice_catalogue view
//   - the set_updated_at BEFORE UPDATE trigger
// They are added in prisma/migrations/*/migration.sql after the generated tables.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm"), unaccent]
}

// ─────────────────────────── enums (§2) ───────────────────────────

enum UserRole {
  customer
  delivery
  admin

  @@map("user_role")
}

enum OrderStatus {
  placed
  payment_pending_verification
  payment_failed
  confirmed
  packed
  out_for_delivery
  delivered
  cancelled
  returned

  @@map("order_status")
}

enum PaymentMethod {
  upi
  cod

  @@map("payment_method")
}

enum PaymentStatus {
  pending_verification
  verified
  rejected
  collected
  refunded

  @@map("payment_status")
}

enum OrderSource {
  manual
  voice
  admin

  @@map("order_source")
}

enum MovementReason {
  purchase
  sale
  damage
  expiry
  shop_use
  correction
  return

  @@map("movement_reason")
}

enum UnitType {
  kg
  g
  l
  ml
  piece
  packet
  dozen
  bundle

  @@map("unit_type")
}

// ─────────────────────────── core tables (§3) ───────────────────────────

model User {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone     String   @unique
  fullName  String?  @map("full_name")
  role      UserRole @default(customer)
  language  String   @default("kn")
  isActive  Boolean  @default(true) @map("is_active")
  isBlocked Boolean  @default(false) @map("is_blocked")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  addresses          Address[]
  refreshTokens      RefreshToken[]
  cart               Cart?
  orders             Order[]
  voiceSessions      VoiceSession[]
  deviceTokens       DeviceToken[]
  inventoryMovements InventoryMovement[]
  statusEvents       OrderStatusEvent[]
  paymentsVerified   Payment[]            @relation("PaymentVerifiedBy")
  paymentsCollected  Payment[]            @relation("PaymentCollectedBy")
  deliveriesAssigned DeliveryAssignment[] @relation("AssignmentDeliveryUser")
  assignmentsCreated DeliveryAssignment[] @relation("AssignmentAssignedBy")
  auditLogs          AuditLog[]

  @@map("users")
}

model OtpCode {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone      String
  codeHash   String    @map("code_hash")
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone, createdAt(sort: Desc)])
  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("refresh_tokens")
}

model Address {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String?  @default("Home")
  line1     String
  line2     String?
  area      String
  landmark  String?
  city      String   @default("Mysuru")
  pincode   String
  latitude  Float?   @db.DoublePrecision
  longitude Float?   @db.DoublePrecision
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Category {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nameEn    String  @map("name_en")
  nameKn    String  @map("name_kn")
  nameHi    String  @map("name_hi")
  slug      String  @unique
  iconUrl   String? @map("icon_url")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  nameEn        String   @map("name_en")
  nameKn        String   @map("name_kn")
  nameHi        String   @map("name_hi")
  brand         String?
  descriptionEn String?  @map("description_en")
  descriptionKn String?  @map("description_kn")
  descriptionHi String?  @map("description_hi")
  imageUrl      String?  @map("image_url")
  hsnCode       String?  @map("hsn_code")
  isAvailable   Boolean  @default(true) @map("is_available")
  isPerishable  Boolean  @default(false) @map("is_perishable")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  category Category         @relation(fields: [categoryId], references: [id])
  aliases  ProductAlias[]
  variants ProductVariant[]

  @@index([nameEn(ops: raw("gin_trgm_ops"))], type: Gin, map: "products_name_en_trgm")
  @@index([nameKn(ops: raw("gin_trgm_ops"))], type: Gin, map: "products_name_kn_trgm")
  @@index([nameHi(ops: raw("gin_trgm_ops"))], type: Gin, map: "products_name_hi_trgm")
  @@map("products")
}

model ProductAlias {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  alias     String
  language  String?
  source    String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, alias])
  @@index([productId])
  @@index([alias(ops: raw("gin_trgm_ops"))], type: Gin, map: "product_aliases_trgm")
  @@map("product_aliases")
}

model ProductVariant {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  sku               String   @unique
  packSize          Decimal  @map("pack_size") @db.Decimal(10, 3)
  unit              UnitType
  packLabel         String   @map("pack_label")
  mrp               Decimal  @db.Decimal(10, 2)
  sellingPrice      Decimal  @map("selling_price") @db.Decimal(10, 2)
  costPrice         Decimal? @map("cost_price") @db.Decimal(10, 2)
  stock             Decimal  @default(0) @db.Decimal(10, 3)
  lowStockThreshold Decimal  @default(5) @map("low_stock_threshold") @db.Decimal(10, 3)
  isDefault         Boolean  @default(false) @map("is_default")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockBatches       StockBatch[]
  inventoryMovements InventoryMovement[]
  cartItems          CartItem[]
  orderItems         OrderItem[]

  @@map("product_variants")
}

model Supplier {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String
  phone     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  stockBatches StockBatch[]

  @@map("suppliers")
}

model StockBatch {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  variantId   String    @map("variant_id") @db.Uuid
  supplierId  String?   @map("supplier_id") @db.Uuid
  quantity    Decimal   @db.Decimal(10, 3)
  costPerUnit Decimal?  @map("cost_per_unit") @db.Decimal(10, 2)
  batchCode   String?   @map("batch_code")
  expiryDate  DateTime? @map("expiry_date") @db.Date
  receivedAt  DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)

  variant            ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  inventoryMovements InventoryMovement[]

  @@index([variantId])
  @@map("stock_batches")
}

model InventoryMovement {
  id        String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  variantId String         @map("variant_id") @db.Uuid
  delta     Decimal        @db.Decimal(10, 3)
  reason    MovementReason
  orderId   String?        @map("order_id") @db.Uuid
  batchId   String?        @map("batch_id") @db.Uuid
  note      String?
  actorId   String?        @map("actor_id") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  variant ProductVariant @relation(fields: [variantId], references: [id])
  order   Order?         @relation(fields: [orderId], references: [id])
  batch   StockBatch?    @relation(fields: [batchId], references: [id])
  actor   User?          @relation(fields: [actorId], references: [id])

  @@index([variantId, createdAt(sort: Desc)])
  @@index([orderId])
  @@map("inventory_movements")
}

model Cart {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cartId    String      @map("cart_id") @db.Uuid
  variantId String      @map("variant_id") @db.Uuid
  quantity  Decimal     @db.Decimal(10, 3)
  addedVia  OrderSource @default(manual) @map("added_via")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model Order {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderNumber     String        @unique @map("order_number")
  userId          String        @map("user_id") @db.Uuid
  addressId       String        @map("address_id") @db.Uuid
  status          OrderStatus   @default(placed)
  source          OrderSource   @default(manual)
  paymentMethod   PaymentMethod @map("payment_method")
  subtotal        Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  deliverySlot    String?       @map("delivery_slot")
  customerNote    String?       @map("customer_note")
  cancelReason    String?       @map("cancel_reason")
  addressSnapshot Json          @map("address_snapshot") @db.JsonB
  voiceSessionId  String?       @map("voice_session_id") @db.Uuid
  placedAt        DateTime      @default(now()) @map("placed_at") @db.Timestamptz(6)
  confirmedAt     DateTime?     @map("confirmed_at") @db.Timestamptz(6)
  deliveredAt     DateTime?     @map("delivered_at") @db.Timestamptz(6)
  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  user                User                 @relation(fields: [userId], references: [id])
  address             Address              @relation(fields: [addressId], references: [id])
  voiceSession        VoiceSession?        @relation("OrderVoiceSession", fields: [voiceSessionId], references: [id])
  items               OrderItem[]
  statusEvents        OrderStatusEvent[]
  payments            Payment[]
  deliveryAssignments DeliveryAssignment[]
  invoice             Invoice?
  inventoryMovements  InventoryMovement[]
  voiceSessionResults VoiceSession[]       @relation("VoiceSessionResultOrder")

  @@index([userId, placedAt(sort: Desc)])
  @@index([status, placedAt(sort: Desc)])
  @@index([placedAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId       String      @map("order_id") @db.Uuid
  variantId     String      @map("variant_id") @db.Uuid
  quantity      Decimal     @db.Decimal(10, 3)
  unitPrice     Decimal     @map("unit_price") @db.Decimal(10, 2)
  lineTotal     Decimal     @map("line_total") @db.Decimal(10, 2)
  productNameEn String      @map("product_name_en")
  productNameKn String      @map("product_name_kn")
  productNameHi String      @map("product_name_hi")
  packLabel     String      @map("pack_label")
  hsnCode       String?     @map("hsn_code")
  addedVia      OrderSource @default(manual) @map("added_via")

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusEvent {
  id               String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId          String      @map("order_id") @db.Uuid
  status           OrderStatus
  actorId          String?     @map("actor_id") @db.Uuid
  note             String?
  clientMutationId String?     @unique @map("client_mutation_id")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([orderId, createdAt])
  @@map("order_status_events")
}

model Payment {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId          String        @map("order_id") @db.Uuid
  method           PaymentMethod
  amount           Decimal       @db.Decimal(10, 2)
  status           PaymentStatus
  upiReference     String?       @map("upi_reference")
  proofImageUrl    String?       @map("proof_image_url")
  submittedAt      DateTime?     @map("submitted_at") @db.Timestamptz(6)
  verifiedBy       String?       @map("verified_by") @db.Uuid
  verifiedAt       DateTime?     @map("verified_at") @db.Timestamptz(6)
  rejectionReason  String?       @map("rejection_reason")
  collectedBy      String?       @map("collected_by") @db.Uuid
  collectedAt      DateTime?     @map("collected_at") @db.Timestamptz(6)
  amountCollected  Decimal?      @map("amount_collected") @db.Decimal(10, 2)
  gateway          String?
  gatewayPaymentId String?       @map("gateway_payment_id")
  note             String?
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifier  User? @relation("PaymentVerifiedBy", fields: [verifiedBy], references: [id])
  collector User? @relation("PaymentCollectedBy", fields: [collectedBy], references: [id])

  @@index([orderId])
  @@index([collectedBy, collectedAt])
  @@map("payments")
}

model DeliveryAssignment {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId        String    @map("order_id") @db.Uuid
  deliveryUserId String    @map("delivery_user_id") @db.Uuid
  assignedBy     String    @map("assigned_by") @db.Uuid
  assignedAt     DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  pickedUpAt     DateTime? @map("picked_up_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  isActive       Boolean   @default(true) @map("is_active")
  failureReason  String?   @map("failure_reason")

  order        Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryUser User  @relation("AssignmentDeliveryUser", fields: [deliveryUserId], references: [id])
  assigner     User  @relation("AssignmentAssignedBy", fields: [assignedBy], references: [id])

  @@index([deliveryUserId, isActive])
  @@map("delivery_assignments")
}

model Invoice {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId       String   @unique @map("order_id") @db.Uuid
  invoiceNumber String   @unique @map("invoice_number")
  pdfUrl        String?  @map("pdf_url")
  total         Decimal  @db.Decimal(10, 2)
  gstEnabled    Boolean  @default(false) @map("gst_enabled")
  cgst          Decimal? @default(0) @db.Decimal(10, 2)
  sgst          Decimal? @default(0) @db.Decimal(10, 2)
  issuedAt      DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

model VoiceSession {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  audioPath        String?  @map("audio_path")
  transcript       String?
  detectedLanguage String?  @map("detected_language")
  sttProvider      String?  @map("stt_provider")
  sttConfidence    Float?   @map("stt_confidence") @db.Real
  parsedResult     Json?    @map("parsed_result") @db.JsonB
  matchedCount     Int      @default(0) @map("matched_count")
  ambiguousCount   Int      @default(0) @map("ambiguous_count")
  unmatchedCount   Int      @default(0) @map("unmatched_count")
  unmatchedTerms   String[] @map("unmatched_terms")
  resultedInOrder  Boolean  @default(false) @map("resulted_in_order")
  orderId          String?  @map("order_id") @db.Uuid
  latencyMs        Int?     @map("latency_ms")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resultOrder Order?  @relation("VoiceSessionResultOrder", fields: [orderId], references: [id])
  ordersUsing Order[] @relation("OrderVoiceSession")

  @@index([userId, createdAt(sort: Desc)])
  @@map("voice_sessions")
}

model ShopSettings {
  id                Int      @id @default(1)
  shopName          String   @default("Krishnappa Shetty and Son's") @map("shop_name")
  shopPhone         String   @map("shop_phone")
  shopAddress       String   @map("shop_address")
  isOpen            Boolean  @default(true) @map("is_open")
  opensAt           DateTime @default(dbgenerated("'07:00:00'::time without time zone")) @map("opens_at") @db.Time(6)
  closesAt          DateTime @default(dbgenerated("'21:00:00'::time without time zone")) @map("closes_at") @db.Time(6)
  acceptingOrders   Boolean  @default(true) @map("accepting_orders")
  deliveryFee       Decimal  @default(20) @map("delivery_fee") @db.Decimal(10, 2)
  freeDeliveryAbove Decimal  @default(500) @map("free_delivery_above") @db.Decimal(10, 2)
  deliveryRadiusKm  Decimal  @default(5) @map("delivery_radius_km") @db.Decimal(5, 2)
  codLimit          Decimal  @default(3000) @map("cod_limit") @db.Decimal(10, 2)
  upiVpa            String?  @map("upi_vpa")
  upiPayeeName      String?  @map("upi_payee_name")
  upiQrUrl          String?  @map("upi_qr_url")
  gstEnabled        Boolean  @default(false) @map("gst_enabled")
  gstin             String?
  invoicePrefix     String   @default("KSS") @map("invoice_prefix")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("shop_settings")
}

model DeviceToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String?
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id") @db.Uuid
  before    Json?    @db.JsonB
  after     Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entity, entityId, createdAt(sort: Desc)])
  @@map("audit_log")
}
